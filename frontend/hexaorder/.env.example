# cat > .env.example << 'EOF'
# # Application
# VITE_APP_NAME=HexaOrder
# VITE_APP_VERSION=1.0.0

# # API Configuration (when integrating real backend)
# # VITE_API_URL=http://localhost:3000/api
# # VITE_API_TIMEOUT=10000

# # Copy this to .env.development for local development
# VITE_API_BASE_URL=http://localhost:8080/api

# # Feature Flags
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_NOTIFICATIONS=true

# # Development
# NODE_ENV=development
# EOF

# ================================================================
# hexaorder/.env.example
#
# PURPOSE : Template for local Vite development server (npm run dev).
#           This is NOT used by Docker — Docker uses build ARGs.
# USAGE   : cp .env.example .env.local  →  fill in real values
# COMMIT  : YES — no real secrets here, commit it.
#
# ── How Vite env vars work ───────────────────────────────────
# Only variables prefixed with VITE_ are exposed to the browser.
# They are read at BUILD time (not runtime) by Vite.
# Access them in code as: import.meta.env.VITE_API_BASE_URL
# ================================================================


# ── API base URL ─────────────────────────────────────────────
# LOCAL (npm run dev): point directly at the Spring Boot dev server.
# This is the ONLY variable you need for local dev without Docker.
VITE_API_BASE_URL=http://localhost:8080/api


# ── App metadata (optional, for display purposes) ────────────
VITE_APP_NAME=HexaOrder
VITE_APP_VERSION=1.0.0
