# build
# EOF

# node_modules/
# dist/
# .env
# .vscode/
# .idea/

# ================================================================
# .gitignore — hexaorder (React / Vite / TypeScript Frontend)
# ================================================================


# ── Build output ─────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
.vite/


# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz


# ── Environment / secrets ────────────────────────────────────
# .env.example IS committed — it documents required variables.
# All real .env files are blocked.
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging


# ── TypeScript build cache ───────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo
tsconfig.app.tsbuildinfo
tsconfig.node.tsbuildinfo


# ── Test / coverage ──────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/


# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ── IDE — VS Code ────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
*.code-workspace


# ── IDE — IntelliJ IDEA / WebStorm ───────────────────────────
.idea/
*.iml


# ── OS artefacts ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# ── Misc ─────────────────────────────────────────────────────
*.local
*.sw?
*.bak
*~
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.prettiercache


# ── Storybook (if added later) ───────────────────────────────
storybook-static/