# ================================================================
# devops/.env.example
#
# PURPOSE : Documents every variable the stack needs locally.
# USAGE   : cp .env.example .env  →  fill in real values in .env
# COMMIT  : YES — this file has no real secrets, commit it.
# ================================================================


# ── PostgreSQL (local Docker container) ──────────────────────
# Used by the postgres service AND the backend service.
POSTGRES_DB=MultiUserDB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password


# ── Spring Boot datasource ───────────────────────────────────
# For local docker-compose, this points at the postgres service
# container by its service name "postgres" (Docker DNS).
# For production (RDS) override this in .env.prod.
DB_URL=jdbc:postgresql://postgres:5432/MultiUserDB
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_strong_password


# ── JWT ──────────────────────────────────────────────────────
# Must be at least 256 bits (32+ chars). Use a long random string.
# Generate one with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_replace_with_long_random_secret_min_32_chars


# ── Email — Gmail SMTP ───────────────────────────────────────
# Use a Gmail App Password (not your real Gmail password).
# Enable at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD=CHANGE_ME_gmail_app_password


# ── Twilio (SMS / OTP) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=CHANGE_ME_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX


# ── Google OAuth2 ────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com
# Authorised redirect URI for local: http://localhost/login/oauth2/code/google
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME_google_client_secret


# ── Cloudinary (image uploads) ───────────────────────────────
CLOUDINARY_CLOUD_NAME=CHANGE_ME_cloud_name
CLOUDINARY_API_KEY=CHANGE_ME_cloudinary_api_key
CLOUDINARY_API_SECRET=CHANGE_ME_cloudinary_api_secret


# ── AWS S3 ───────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=s3-hex-multiuser
AWS_ACCESS_KEY_ID=CHANGE_ME_aws_access_key_id
AWS_SECRET_ACCESS_KEY=CHANGE_ME_aws_secret_access_key


# ── CORS / Frontend URL ──────────────────────────────────────
# For local docker-compose, the frontend is served at http://localhost
# (Nginx on port 80). No port number needed since port 80 is default.
APP_FRONTEND_URL=http://localhost
APP_CORS_ALLOWED_ORIGINS=http://localhost
APP_OAUTH2_REDIRECT_URI=http://localhost/oauth2/callback


# ── Vite build-time API base URL ─────────────────────────────
# "/api" means: same origin, Nginx proxies /api/** → backend:8080.
# This eliminates CORS entirely for the Docker setup.
# Do NOT change this unless you know what you are doing.
VITE_API_BASE_URL=/api
