
DB_URL=jdbc:postgresql://CHANGE_ME_rds_endpoint:5432/MultiUserDB
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_rds_master_password


# ── JWT ──────────────────────────────────────────────────────
# Use a DIFFERENT secret from your local .env.
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_production_jwt_secret_min_64_chars_long


# ── Email — Gmail SMTP ───────────────────────────────────────
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD=CHANGE_ME_gmail_app_password


# ── Twilio (SMS / OTP) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=CHANGE_ME_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX


# ── Google OAuth2 ────────────────────────────────────────────
# IMPORTANT: Add the EC2 public IP/domain to Google Console:
#   Authorised redirect URIs:
#     http://<EC2-IP>/login/oauth2/code/google
#   Authorised JavaScript origins:
#     http://<EC2-IP>
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME_google_client_secret


# ── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=CHANGE_ME_cloud_name
CLOUDINARY_API_KEY=CHANGE_ME_cloudinary_api_key
CLOUDINARY_API_SECRET=CHANGE_ME_cloudinary_api_secret


# ── AWS S3 ───────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=s3-hex-multiuser
AWS_ACCESS_KEY_ID=CHANGE_ME_aws_access_key_id
AWS_SECRET_ACCESS_KEY=CHANGE_ME_aws_secret_access_key


# ── CORS / Frontend URL ──────────────────────────────────────
# Replace <EC2-PUBLIC-IP> with your actual EC2 public IPv4 address.
# Find it: AWS Console → EC2 → Instances → multi-user-hex-ui → Public IPv4
# If you have a domain name, use that instead (e.g. https://yourdomain.com).
APP_FRONTEND_URL=http://CHANGE_ME_ec2_public_ip
APP_CORS_ALLOWED_ORIGINS=http://CHANGE_ME_ec2_public_ip
APP_OAUTH2_REDIRECT_URI=http://CHANGE_ME_ec2_public_ip/oauth2/callback


# ── Vite build-time API base URL ─────────────────────────────
# "/api" works the same in production — Nginx proxies it.
# Do NOT change this.
VITE_API_BASE_URL=/api
